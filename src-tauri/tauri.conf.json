{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SAELABEL",
  "version": "0.1.0",
  "identifier": "dev.eskender.saelabel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:4321",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SAELABEL",
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "width": 1200,
        "height": 860,
        "resizable": true,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
