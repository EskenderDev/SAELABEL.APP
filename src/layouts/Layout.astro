<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SAELABEL App</title>
    <style>
      :root {
        --bg: #f7f8fa;
        --panel: #ffffff;
        --text: #101820;
        --muted: #4d5a66;
        --accent: #0f7b6c;
        --border: #d8dee4;
      }

      body {
        margin: 0;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background: radial-gradient(circle at top right, #e5f5f2 0%, var(--bg) 45%);
        color: var(--text);
      }

      main {
        max-width: 920px;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem;
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
